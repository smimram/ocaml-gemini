opam-version: "2.0"
synopsis: "OCaml library for interacting with the Gemini API"
description: "OCaml bindings and client utilities for the Gemini API"
maintainer: ["Samuel Mimram <smimram@gmail.com>"]
authors: ["Samuel Mimram <smimram@gmail.com>"]
license: "MIT"
homepage: "https://github.com/smimram/ocaml-gemini"
bug-reports: "https://github.com/smimram/ocaml-gemini/issues"
depends: [
  "ocaml"
  "dune" {>= "3.13"}
  "lwt"
  "cohttp-lwt-unix"
  "yojson"
  "uri"
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/smimram/ocaml-gemini.git"
